{
  "expo": {
    "name": "app",
    "slug": "app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "app",
    "userInterfaceStyle": "dark",
    "icon": "./assets/logoAPP.png",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/logoAPP.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logoAPP.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.daviaugusto479.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logoAPP.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logoAPP.png",
          "imageWidth": 400,
          "resizeMode": "contain"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc05256b-111f-4945-8d0d-013d40dbea3c"
      }
    }
  }
}
